{
  "features": {
    "description": "功能开关与调用链（按顺序兜底）",
    "hint": "先在最底部添加 providers（服务商），再在这里为每个功能选择 provider 链路（第一个=主用，后续=兜底）。",
    "type": "object",
    "items": {
      "draw": {
        "description": "文生图 (Text-to-Image)",
        "type": "object",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用文生图",
            "default": true
          },
          "llm_tool_enabled": {
            "type": "bool",
            "description": "允许 LLM 调用文生图",
            "hint": "关闭后，即使 LLM 调用 aiimg_generate(mode=text) 也会被拒绝。",
            "default": true
          },
          "default_output": {
            "type": "string",
            "description": "默认输出尺寸/分辨率",
            "hint": "例：4K / 2K / 1K / 2048x2048 / 4096x4096。留空则由服务商默认决定。",
            "options": [
              "1K",
              "2K",
              "4K",
              "256x256",
              "512x512",
              "1024x1024",
              "2048x2048",
              "1152x896",
              "2048x1536",
              "768x1024",
              "1536x2048",
              "2048x1360",
              "1360x2048",
              "1024x576",
              "2048x1152",
              "576x1024",
              "1152x2048"
            ],
            "default": "1024x1024"
          },
          "ratio_default_sizes": {
            "type": "object",
            "description": "比例到默认尺寸的映射（仅 /aiimg 比例生效）",
            "hint": "键为比例（如 1:1 / 16:9），值为尺寸（如 1024x1024）。请使用 Gitee 支持的尺寸；留空使用内置默认。",
            "default": {},
            "items": {}
          },
          "chain": {
            "type": "template_list",
            "description": "文生图服务商链路",
            "hint": "按顺序兜底：第一个=主用，其余=失败后自动切换。",
            "templates": {
              "provider": {
                "name": "Provider",
                "items": {
                  "provider_id": {
                    "type": "string",
                    "description": "服务商 ID",
                    "hint": "填写你在 providers 里配置的 id（必须完全一致）。",
                    "default": ""
                  },
                  "output": {
                    "type": "string",
                    "description": "覆盖输出",
                    "hint": "留空使用 default_output；例：4K 或 2048x2048。",
                    "default": ""
                  }
                }
              }
            }
          }
        }
      },
      "edit": {
        "description": "图生图/改图 (Image-to-Image/Edit)",
        "type": "object",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用改图",
            "default": true
          },
          "llm_tool_enabled": {
            "type": "bool",
            "description": "允许 LLM 调用改图",
            "hint": "关闭后，即使 LLM 调用 aiimg_generate(mode=edit) 也会被拒绝。",
            "default": true
          },
          "default_output": {
            "type": "string",
            "description": "默认输出尺寸/分辨率",
            "hint": "例：4K / 2048x2048。留空则由服务商默认决定。",
            "default": "4K"
          },
          "chain": {
            "type": "template_list",
            "description": "改图服务商链路",
            "hint": "按顺序兜底：第一个=主用，其余=失败后自动切换。",
            "templates": {
              "provider": {
                "name": "Provider",
                "items": {
                  "provider_id": {
                    "type": "string",
                    "description": "服务商 ID",
                    "hint": "填写你在 providers 里配置的 id（必须完全一致）。",
                    "default": ""
                  },
                  "output": {
                    "type": "string",
                    "description": "覆盖输出",
                    "hint": "留空使用 default_output；例：4K 或 2048x2048。",
                    "default": ""
                  }
                }
              }
            }
          },
          "gitee_task_types": {
            "type": "list",
            "description": "Gitee 异步改图默认任务类型",
            "hint": "仅对 providers 中的 gitee_async 类型生效。默认：id/background/style。",
            "default": [
              "id",
              "background",
              "style"
            ]
          },
          "presets": {
            "type": "list",
            "description": "改图预设提示词",
            "hint": "格式：预设名:英文提示词。例如：手办化:Transform into figurine style",
            "default": []
          }
        }
      },
      "video": {
        "description": "视频生成 (Image-to-Video)",
        "type": "object",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用视频生成",
            "default": false
          },
          "llm_tool_enabled": {
            "type": "bool",
            "description": "允许 LLM 调用视频生成",
            "default": true
          },
          "chain": {
            "type": "template_list",
            "description": "视频服务商链路",
            "hint": "按顺序兜底：第一个=主用，其余=失败后自动切换。",
            "templates": {
              "provider": {
                "name": "Provider",
                "items": {
                  "provider_id": {
                    "type": "string",
                    "description": "服务商 ID",
                    "default": ""
                  }
                }
              }
            }
          },
          "presets": {
            "type": "list",
            "description": "视频预设提示词",
            "hint": "格式：预设名:英文提示词。例如：日常:Daily outfit, cinematic, walking",
            "default": []
          },
          "send_mode": {
            "type": "string",
            "description": "发送方式",
            "hint": "auto=URL失败再下载；url=仅URL；file=下载后本地文件",
            "options": [
              "auto",
              "url",
              "file"
            ],
            "default": "auto"
          },
          "send_timeout_seconds": {
            "type": "int",
            "description": "发送超时(秒)",
            "hint": "发送 Video 组件等待时间",
            "slider": {
              "min": 10,
              "max": 300,
              "step": 10
            },
            "default": 90
          },
          "download_timeout_seconds": {
            "type": "int",
            "description": "下载视频超时(秒)",
            "hint": "send_mode=file/auto 时用于下载",
            "slider": {
              "min": 30,
              "max": 3600,
              "step": 30
            },
            "default": 300
          }
        }
      },
      "selfie": {
        "description": "Bot 自拍 (Selfie)",
        "type": "object",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用自拍功能",
            "default": true
          },
          "llm_tool_enabled": {
            "type": "bool",
            "description": "允许 LLM 调用自拍",
            "hint": "关闭后，即使 LLM 调用 aiimg_generate(mode=selfie_ref) 也会被拒绝。",
            "default": true
          },
          "wardrobe_ref_enabled": {
            "type": "bool",
            "description": "启用衣橱参考图",
            "hint": "开启后，自拍时会从衣橱插件获取参考图并追加到人设参考图后面。需要衣橱插件已安装且已配置取图模型。",
            "default": false
          },
          "daily_selfie_schedule_time": {
            "type": "string",
            "description": "每日自拍补画触发时间",
            "hint": "每天在此时间自动检查并补画未用完的额度。格式：HH:MM，如 23:00。",
            "default": "23:00"
          },
          "daily_selfie_retry_on_fail": {
            "type": "bool",
            "description": "失败自动重试",
            "hint": "开启后，补画失败或超时的图片会自动重新生成，直到当天额度用完。每次重试间隔30秒。",
            "default": true
          },
          "daily_selfie_chat_provider_id": {
            "type": "string",
            "description": "补画对话模型",
            "hint": "补画时用于生成风格查询和构建提示词的 LLM 提供商。留空则使用当前会话的对话模型。",
            "default": "",
            "_special": "select_provider"
          },
          "daily_selfie_debug": {
            "type": "bool",
            "description": "补画 Debug 模式",
            "hint": "开启后，补画时会在日志中输出 LLM 每轮的完整请求与返回，便于排查提示词问题。",
            "default": false
          },
          "daily_selfie_ref_min_similarity": {
            "type": "float",
            "description": "补拍搜图相似度阈值",
            "hint": "补画时从衣橱搜参考图的向量相似度阈值（0.0~1.0）。设为0则使用衣橱全局阈值（默认0.5）；设为0.6~0.7可增加「无参考图自由发挥」的比例，缓解图库有限时的重复问题。仅影响补拍搜图，不影响日常取图。",
            "default": 0.0
          }
        }
      },
      "selfie_persona_1": {
        "description": "人格1自拍配置",
        "type": "object",
        "items": {
          "select_persona": {
            "type": "string",
            "description": "人格",
            "default": "default",
            "_special": "select_persona"
          },
          "reference_images": {
            "type": "file",
            "description": "参考人像",
            "hint": "建议上传清晰正脸照，可多张。",
            "default": [],
            "file_types": [
              "jpg",
              "jpeg",
              "png",
              "webp"
            ]
          },
          "default_output": {
            "type": "string",
            "description": "默认输出尺寸/分辨率",
            "hint": "例：4K / 2048x2048。留空则由服务商默认决定。",
            "default": "4K"
          },
          "provider_ids": {
            "type": "list",
            "description": "自拍服务商链路（按顺序兜底）",
            "hint": "填写 providers 里配置的 id，第一个=主用，后面的=失败后自动切换。",
            "default": []
          },
          "prompt_prefix": {
            "type": "text",
            "description": "自拍提示词前缀",
            "hint": "留空使用内置默认。会在最终提示词前自动添加。",
            "default": ""
          },
          "daily_selfie_enabled": {
            "type": "bool",
            "description": "启用每日补画",
            "hint": "开启后，该人格将参与每日自动补画，在额度未用完时自动生成自拍。",
            "default": false
          },
          "daily_selfie_limit": {
            "type": "int",
            "description": "每日画图额度上限",
            "hint": "该提供商每天允许的最大画图次数，超过后不再补画。",
            "default": 20
          },
          "daily_selfie_provider_id": {
            "type": "string",
            "description": "补画计数的提供商ID",
            "hint": "填写 providers 里配置的 id，用于统计该提供商的每日使用次数。",
            "default": ""
          },
          "video_provider_ids": {
            "type": "list",
            "description": "视频服务商链路（按顺序兜底）",
            "hint": "填写 providers 里配置的 id，第一个=主用，后面的=失败后自动切换。留空则使用全局视频链路。",
            "default": []
          },
          "daily_selfie_schedule_time": {
            "type": "string",
            "description": "补画触发时间（人格级）",
            "hint": "覆盖全局补画时间。格式：HH:MM，如 23:30。留空使用全局设置。",
            "default": ""
          },
          "daily_selfie_qzone_publish_enabled": {
            "type": "bool",
            "description": "补画完成后自动发空间说说",
            "hint": "开启后，每日补画完成后会用生成的图片发一条QQ空间说说。需要先配置下方多模态提供商。",
            "default": false
          },
          "daily_selfie_qzone_chat_provider_id": {
            "type": "string",
            "description": "说说配文多模态模型",
            "hint": "补画完成后用于看图写说说配文的 LLM 提供商。需要支持多模态（图片输入）。留空或不启用上方开关则不会发布。",
            "default": "",
            "_special": "select_provider"
          }
        }
      },
      "selfie_persona_2": {
        "description": "人格2自拍配置",
        "type": "object",
        "items": {
          "select_persona": {
            "type": "string",
            "description": "人格",
            "default": "default",
            "_special": "select_persona"
          },
          "reference_images": {
            "type": "file",
            "description": "参考人像",
            "hint": "建议上传清晰正脸照，可多张。",
            "default": [],
            "file_types": [
              "jpg",
              "jpeg",
              "png",
              "webp"
            ]
          },
          "default_output": {
            "type": "string",
            "description": "默认输出尺寸/分辨率",
            "hint": "例：4K / 2048x2048。留空则由服务商默认决定。",
            "default": "4K"
          },
          "provider_ids": {
            "type": "list",
            "description": "自拍服务商链路（按顺序兜底）",
            "hint": "填写 providers 里配置的 id，第一个=主用，后面的=失败后自动切换。",
            "default": []
          },
          "prompt_prefix": {
            "type": "text",
            "description": "自拍提示词前缀",
            "hint": "留空使用内置默认。会在最终提示词前自动添加。",
            "default": ""
          },
          "daily_selfie_enabled": {
            "type": "bool",
            "description": "启用每日补画",
            "hint": "开启后，该人格将参与每日自动补画，在额度未用完时自动生成自拍。",
            "default": false
          },
          "daily_selfie_limit": {
            "type": "int",
            "description": "每日画图额度上限",
            "hint": "该提供商每天允许的最大画图次数，超过后不再补画。",
            "default": 20
          },
          "daily_selfie_provider_id": {
            "type": "string",
            "description": "补画计数的提供商ID",
            "hint": "填写 providers 里配置的 id，用于统计该提供商的每日使用次数。",
            "default": ""
          },
          "video_provider_ids": {
            "type": "list",
            "description": "视频服务商链路（按顺序兜底）",
            "hint": "填写 providers 里配置的 id，第一个=主用，后面的=失败后自动切换。留空则使用全局视频链路。",
            "default": []
          },
          "daily_selfie_schedule_time": {
            "type": "string",
            "description": "补画触发时间（人格级）",
