            "default": "",
            "_special": "select_provider"
          }
        }
      }
    }
  },
  "llm_tool": {
    "description": "LLM 工具调用行为",
    "type": "object",
    "items": {
      "image_context_mode": {
        "type": "string",
        "description": "图片生成后返回给 LLM 上下文的方式",
        "hint": "可选值：image（返回压缩图，LLM可识别图片内容并回复）/ text（返回提示词文字描述）/ none（不返回）。默认 image。仅在后台生成模式关闭时生效。",
        "default": "image"
      },
      "background_generate": {
        "type": "bool",
        "description": "后台生成模式（不阻塞对话）",
        "hint": "开启后，LLM调用画图工具时会立即返回，图片在后台生成完成后自动发送。期间你可以继续和bot聊天。关闭则等待图片生成完毕后才继续对话（LLM可在上下文中看到图片）。",
        "default": true
      }
    }
  },
  "storage": {
    "description": "缓存与存储",
    "type": "object",
    "items": {
      "max_cached_images": {
        "description": "图片最大缓存数",
        "hint": "超过此数时，将清理一半的旧缓存图",
        "type": "int",
        "slider": {
          "min": 10,
          "max": 500,
          "step": 1
        },
        "default": 50
      },
      "max_cached_videos": {
        "description": "本地视频最大缓存数",
        "hint": "仅在 send_mode=file/auto 且触发下载时生效（0=不清理）",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 500,
          "step": 1
        },
        "default": 20
      }
    }
  },
  "debounce_interval": {
    "description": "防抖时长(秒)",
    "hint": "防抖时间内无法重复提交生成/改图请求，每个用户单独计时",
    "type": "int",
    "slider": {
      "min": 0,
      "max": 60,
      "step": 1
    },
    "default": 10
  },
  "max_user_concurrency": {
    "description": "单用户并发上限（图像）",
    "hint": "同一用户同时进行的文生图/改图/自拍任务数量上限（不含重发）。",
    "type": "int",
    "slider": {
      "min": 1,
      "max": 10,
      "step": 1
    },
    "default": 2
  },
  "max_user_video_concurrency": {
    "description": "单用户并发上限（视频）",
    "hint": "同一用户同时进行的视频任务数量上限。",
    "type": "int",
    "slider": {
      "min": 1,
      "max": 5,
      "step": 1
    },
    "default": 1
  },
  "network": {
    "description": "网络/下载安全配置",
    "hint": "用于图片/视频下载（服务商返回 URL -> 本地缓存/发送）的安全策略。默认阻止本地/LAN/无法解析的地址，以防止 SSRF。",
    "type": "object",
    "items": {
      "media_allow_private": {
        "type": "bool",
        "description": "允许从私有地址下载",
        "hint": "开启后会允许 127.0.0.1/内网IP/内网 DNS 解析等地址（高风险，默认关闭）",
        "default": false
      },
      "max_image_bytes": {
        "type": "int",
        "description": "图片下载大小上限(字节)",
        "hint": "默认 50MB = 52428800",
        "slider": {
          "min": 262144,
          "max": 209715200,
          "step": 262144
        },
        "default": 52428800
      },
      "max_video_bytes": {
        "type": "int",
        "description": "视频下载大小上限(字节)",
        "hint": "默认 50MB = 52428800",
        "slider": {
          "min": 5242880,
          "max": 524288000,
          "step": 5242880
        },
        "default": 52428800
      },
      "max_redirects": {
        "type": "int",
        "description": "最大重定向次数",
        "slider": {
          "min": 0,
          "max": 10,
          "step": 1
        },
        "default": 5
      },
      "dns_resolve_timeout_seconds": {
        "type": "int",
        "description": "DNS 解析超时(秒)",
        "slider": {
          "min": 1,
          "max": 10,
          "step": 1
        },
        "default": 2
      }
    }
  },
  "providers": {
    "description": "模型服务商（可添加多个，id 必须唯一）",
    "hint": "在此配置服务商（url/key/model/超时/代理）；功能链路仅引用 provider_id。",
    "type": "template_list",
    "templates": {
      "openai_images": {
        "name": "OpenAI Images",
        "description": "适用于大多数实现了 /v1/images/* 的 OpenAI 兼容网关（含 gpt-image-2）。",
        "hint": "若服务商只在 Chat 返回图片，请改用 OpenAI Chat 图模板。gpt-image-2 专用字段（quality 等）留空则不传。",
        "items": {
          "id": {
            "type": "string",
            "description": "服务商 ID（唯一）",
            "default": "openai_images"
          },
          "label": {
            "type": "string",
            "description": "显示名称（可选）",
            "default": ""
          },
          "base_url": {
            "type": "string",
            "description": "Base URL",
            "hint": "可填 https://api.example.com 或 https://api.example.com/v1（会自动规范化为包含 /v1）。",
            "default": ""
          },
          "api_keys": {
            "type": "list",
            "description": "API Key 池",
            "default": [],
            "obvious_hint": true
          },
          "model": {
            "type": "string",
            "description": "模型名称",
            "hint": "gpt-image-2 请填 gpt-image-2",
            "default": ""
          },
          "supports_edit": {
            "type": "bool",
            "description": "支持改图 (images.edit)",
            "default": true
          },
          "timeout": {
            "type": "int",
            "description": "超时(秒)",
